{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*\\.(?:css|js|png|jpg|jpeg|gif|svg|ico|json|html))",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/en/offers/united-states/millennium-hotel-broadway-times-square/fifa-2026/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/en/offers/united-states/millennium-hotel-broadway-times-square/fifa-2026/index.html"
    }
  ]
}
